<UserControl x:Class="RentalClient.UserControls.MainWindowView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:RentalClient"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="1000"
             Background="{StaticResource BackgroundBrush}">
    <Grid>
                <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition/>
                </Grid.RowDefinitions>
                
                <!--Header-->
                <Grid Grid.Row="0" Margin="10">
                        <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!--Logo-->
                        <Label Grid.Column="0" 
                                Content="House Find"
                                HorizontalAlignment="Left"
                                Width="150"
                                Style="{StaticResource LogoLabelStyle}"/>
                        
                        <!--SearchField-->
                        <TextBox Grid.Column="1" Width="960" Height="60"
                                HorizontalAlignment="Center"
                                VerticalContentAlignment="Center"
                                Style="{StaticResource SearchTextBoxStyle}"
                                local:Designer.IsMonitoring="True"
                                Tag="  ПОШУК ЗА МІСТОМ/АДРЕСОЮ..."/>
                        
                        
                        <!--LoginButton-->
                        <Button Grid.Column="2" 
                                Style="{StaticResource PrimaryButtonStyle}"
                                Width="120"
                                HorizontalAlignment="Right"
                                Content="Log In"
                                PreviewMouseLeftButtonUp="ProfileButton_Click"/>
                        
                </Grid>
                
                <ContentControl Grid.Row="1" x:Name="WorkplaceHost"/>
        </Grid>
</UserControl>
