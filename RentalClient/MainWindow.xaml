<Window x:Class="RentalClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RentalClient"
        mc:Ignorable="d"
        Title="HouseFind" MinHeight="450" MinWidth="1000"
        WindowState="Maximized"
        Background="FloralWhite">
        
        <Window.Resources>
                <Style x:Key="AnimatedHoverButton" TargetType="Button">
                        <Setter Property="Background">
                            <Setter.Value>
                                <SolidColorBrush Color="Aqua"/>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="20,10"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    
                                    <Border x:Name="Border" 
                                            Background="{TemplateBinding Background}" 
                                            CornerRadius="22"
                                            RenderTransformOrigin="0.5,0.5">
                                        
                                        <Border.RenderTransform>
                                            <ScaleTransform x:Name="ScaleTransform" ScaleX="1" ScaleY="1"/>
                                        </Border.RenderTransform>

                                        <ContentPresenter HorizontalAlignment="Center" 
                                                          VerticalAlignment="Center" 
                                                          Margin="{TemplateBinding Padding}"/>
                                    </Border>

                                    <ControlTemplate.Triggers>
                                        
                                        <EventTrigger RoutedEvent="MouseEnter">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <ColorAnimation Storyboard.TargetName="Border" 
                                                                    Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" 
                                                                    To="Tomato" Duration="0:0:0.2"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>

                                        <EventTrigger RoutedEvent="MouseLeave">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <ColorAnimation Storyboard.TargetName="Border" 
                                                                    Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" 
                                                                    Duration="0:0:0.2"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                </Style>
            
            <Style x:Key="GlobalText" TargetType="Control">
                <Setter Property="Background" Value="White"/>
                <Setter Property="BorderBrush" Value="SlateGray"/>
                <Setter Property="BorderThickness" Value="1"/>
                
                <Setter Property="Margin" Value="5"></Setter>
                
                <Setter Property="FontFamily" Value="Times New Roman"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="VerticalAlignment" Value="Center"></Setter>
            </Style>
            
            <Style x:Key="ToggleButton" TargetType="ToggleButton" BasedOn="{StaticResource GlobalText}">
                
            </Style>
            
            <Style x:Key="FilterTextField" TargetType="TextBox" BasedOn="{StaticResource GlobalText}">
                
            </Style>
            
            <Style x:Key="FilterLabel" TargetType="Label" BasedOn="{StaticResource GlobalText}">
                <Setter Property="BorderThickness" Value="0"></Setter>
                <Setter Property="FontSize" Value="20"></Setter>
            </Style>
            
        </Window.Resources>
        <Grid>
                <Grid.RowDefinitions>
                        <RowDefinition Height="70"/>
                        <RowDefinition/>
                </Grid.RowDefinitions>
                
                <!--Header-->
                <Grid Grid.Row="0" Margin="10">
                        <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!--Logo-->
                        <Border Grid.Column="0" 
                                HorizontalAlignment="Left"
                                Height="40" Width="150"
                                BorderThickness="1" CornerRadius="22" Background="Aqua">
                                
                                <Label FontFamily="Times New Roman" FontSize="20" FontStyle="Oblique"
                                       HorizontalAlignment="Center">House Find</Label>
                        </Border>

                        <!--SearchField-->
                        <Border Grid.Column="1" BorderThickness="2" CornerRadius="22" BorderBrush="Aqua" Background="White"
                                Height="40" Width="600">
                                <TextBox 
                                        Height="40" Width="550"
                                        HorizontalAlignment="Center"
                                        BorderThickness="0"
                                        FontFamily="Times New Roman" FontSize="20"
                                        VerticalContentAlignment="Center"></TextBox>
                        </Border>
                        
                        <!--LoginButton-->
                        <Button Grid.Column="2" 
                                Content="Log In" 
                                Style="{StaticResource AnimatedHoverButton}" 
                                HorizontalAlignment="Right"/>
                                
                        
                </Grid>
                
                <!--WorkPlace-->
                <Grid Grid.Row="1" Margin="10">
                        <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        
                        <!--FilterBox-->
                        <Border Grid.Column="0" 
                                BorderThickness="2" BorderBrush="Aqua" 
                                Background="White"
                                Width="300"
                                HorizontalAlignment="Left">
                                <Grid Margin="10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/> <RowDefinition Height="*"/> <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <Label Grid.Row="0" 
                                           Style="{StaticResource FilterLabel}" FontWeight="Heavy">Фільтр</Label>
                                    
                                    <Grid Grid.Row="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        
                                        <Label Grid.Row="0" Grid.Column="0" Style="{StaticResource FilterLabel}">Ціна:</Label>
                                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBox  Width="60" Height="30" Style="{StaticResource FilterTextField}"></TextBox>
                                            <Label Style="{StaticResource FilterLabel}">-</Label>
                                            <TextBox  Width="60" Height="30" Style="{StaticResource FilterTextField}"></TextBox>
                                        </StackPanel>
                                        
                                        <Label Grid.Row="1" Grid.ColumnSpan="2" Grid.Column="0"
                                               Style="{StaticResource FilterLabel}">Кімнати:</Label>
                                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                                            <ToggleButton Height="30" Width="30" Style="{StaticResource ToggleButton}">1</ToggleButton>
                                            <ToggleButton Height="30" Width="30" Style="{StaticResource ToggleButton}">2</ToggleButton>
                                            <ToggleButton Height="30" Width="30" Style="{StaticResource ToggleButton}">3</ToggleButton>
                                        </StackPanel>
                                        
                                        <Label Grid.Row="2"  Grid.Column="0"
                                               Style="{StaticResource FilterLabel}">Тип:</Label>
                                        <StackPanel Grid.Row="2" Grid.Column="1" HorizontalAlignment="Center">
                                            <ToggleButton Height="30" Width="120" Style="{StaticResource ToggleButton}">Квартира</ToggleButton>
                                            <ToggleButton Height="30" Width="120" Style="{StaticResource ToggleButton}">Будинок</ToggleButton>
                                        </StackPanel>
                                        
                                        <Label Grid.Row="3" Grid.Column="0"
                                               Style="{StaticResource FilterLabel}">Площа:</Label>
                                        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBox  Width="60" Height="30" Style="{StaticResource FilterTextField}"></TextBox>
                                            <Label Style="{StaticResource FilterLabel}">-</Label>
                                            <TextBox  Width="60" Height="30" Style="{StaticResource FilterTextField}"></TextBox>
                                        </StackPanel>
                                    </Grid>
                                    
                                    <Button Grid.Row="2" 
                                            Width="240" Height="40"
                                            Content="Застосувати" Style="{StaticResource AnimatedHoverButton}"
                                            Margin="10"></Button>
                                    
                                </Grid>
                        </Border>
                </Grid>
        </Grid>
</Window>
